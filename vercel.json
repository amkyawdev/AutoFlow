{
  "version": 2,
  "builds": [
    {
      "src": "frontend/src/**",
      "use": "@vercel/static"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/src/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/src/$1"
    }
  ]
}
